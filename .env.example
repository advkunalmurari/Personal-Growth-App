# Life OS — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets to git.
# Store production secrets in: Vercel Dashboard → Project → Environment Variables

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# NEVER expose this client-side. Server-side only (Edge Functions, API routes).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── AI — DeepSeek (primary, 95% cheaper than GPT-4o) ────────────────────────
DEEPSEEK_API_KEY=sk-...

# Anthropic Claude (fallback only)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (second fallback, currently wired in deepseek.ts)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Payments — Razorpay ─────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...
# SERVER-SIDE ONLY — verify: grep -r 'RAZORPAY_KEY_SECRET' src/ → must return 0 results
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ─── Push Notifications ───────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_token_here

# ─── Google Calendar Integration ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/integrations/calendar/callback

# ─── Spotify Integration ─────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ─── WhatsApp / Twilio ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Observability ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App Domain ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.life-os.in

# ─── Security Rule ───────────────────────────────────────────────────────────
# Variables prefixed with NEXT_PUBLIC_ are bundled into the client.
# All SECRET / KEY variables must NEVER have NEXT_PUBLIC_ prefix.
# Audit: grep -r 'process.env.NEXT_PUBLIC' src/ — should never show secrets.
